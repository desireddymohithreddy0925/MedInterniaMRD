PORT=3000
NODE_ENV=development

MONGODB_URI=YOUR_MONGODB_URI_HERE


CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=YOUR_EMAIL_HERE
EMAIL_PASS=YOUR_EMAIL_PASSWORD_HERE

CORS_ORIGINS=http://localhost:3001

# ─── Authentication ────────────────────────────────────────────────────────────
#
# REQUIRED: Minimum 64-character cryptographically random secret
#
# MedInternia handles patient data and medical credentials.
# A weak JWT_SECRET allows attackers to forge authentication tokens offline
# using tools like hashcat, impersonating any doctor or patient.
#
# Generate a strong secret with ONE of these commands:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   openssl rand -hex 64
#   python3 -c "import secrets; print(secrets.token_hex(64))"
#
# The result will be a 128-character hex string — paste the FULL string below.
JWT_SECRET=paste_your_128_character_hex_string_here

# Token expiry (recommended values)
JWT_ACCESS_EXPIRES_IN=15m     # Short-lived — user stays logged in via refresh
JWT_REFRESH_EXPIRES_IN=7d     # Long-lived refresh token stored in httpOnly cookie
# ─── NLP / AI Service (Optional — planned feature, not yet implemented) ────────
# Set NLP_ENABLED=true when the Python NLP microservice is running
NLP_ENABLED=false
NLP_SERVICE_URL=http://localhost:5000
NLP_SERVICE_TIMEOUT_MS=5000    # Timeout for NLP HTTP calls in milliseconds
